% 技术演讲模板配色方案
% 适用场景：技术演讲、会议分享、产品展示
% 设计特点：现代扁平风格，明亮配色，视觉冲击力强

\definecolor{primary}{HTML}{6366F1}       % 现代蓝
\definecolor{secondary}{HTML}{8B5CF6}    % 紫色
\definecolor{accent1}{HTML}{06B6D4}     % 青色
\definecolor{accent2}{HTML}{10B981}     % 绿色
\definecolor{accent3}{HTML}{F59E0B}     % 橙色
\definecolor{lightbg}{HTML}{F8FAFC}      % 极浅背景
\definecolor{darktext}{HTML}{1E293B}     % 深色文本

% 通用样式定义
\tikzset{
    % 主要节点样式
    mainnode/.style={
        rectangle,
        rounded corners=8pt,
        minimum width=3.5cm,
        minimum height=2cm,
        align=center,
        font=\normalsize\bfseries,
        draw=primary!30,
        fill=white,
        drop shadow={opacity=0.2, shadow xshift=3pt, shadow yshift=-3pt}
    },
    % 强调节点样式
    accentnode/.style={
        rectangle,
        rounded corners=8pt,
        minimum width=3cm,
        minimum height=1.8cm,
        align=center,
        font=\normalsize\bfseries,
        draw=accent1!30,
        fill=accent1!8,
        drop shadow={opacity=0.25, shadow xshift=4pt, shadow yshift=-4pt}
    },
    % 数据节点样式
    datanode/.style={
        ellipse,
        minimum width=2.5cm,
        minimum height=1cm,
        align=center,
        font=\normalsize,
        draw=primary!20,
        fill=lightbg
    },
    % 连线样式
    mainarrow/.style={
        ->,
        very thick,
        color=darktext!80
    },
    accentarrow/.style={
        ->,
        very thick,
        color=accent1
    },
    % 标题样式
    title/.style={
        font=\huge\bfseries\color{primary},
        align=center
    }
}